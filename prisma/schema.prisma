// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MITRA
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  poin      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pickups       Pickup[]
  verifications Verification[] @relation("MitraVerifications")
  redemptions   Redemption[]
}

enum PickupCategory {
  HP_LAPTOP
  BATERAI
  KABEL
  PERALATAN_RUMAH_TANGGA
  LAINNYA
}

enum PickupStatus {
  DIAJUKAN
  DIPROSES
  DIJEMPUT
  SELESAI
}

model Pickup {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  kategori   PickupCategory
  deskripsi  String
  fotoUrl    String
  alamat     String
  status     PickupStatus   @default(DIAJUKAN)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  verification Verification?
}

enum ItemCondition {
  BAIK
  RUSAK_RINGAN
  RUSAK_BERAT
}

model Verification {
  id             String         @id @default(cuid())
  pickupId       String         @unique
  pickup         Pickup         @relation(fields: [pickupId], references: [id])
  mitraId        String
  mitra          User           @relation("MitraVerifications", fields: [mitraId], references: [id])
  jumlah         Float
  kondisi        ItemCondition
  fotoBuktiUrl   String
  poinDihasilkan Int
  createdAt      DateTime       @default(now())
}

model Reward {
  id             String   @id @default(cuid())
  nama           String
  deskripsi      String
  poinDibutuhkan Int
  stok           Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  redemptions Redemption[]
}

enum RedemptionStatus {
  DIPROSES
  SELESAI
}

model Redemption {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  rewardId    String
  reward      Reward           @relation(fields: [rewardId], references: [id])
  poinDipakai Int
  status      RedemptionStatus @default(DIPROSES)
  createdAt   DateTime         @default(now())
}